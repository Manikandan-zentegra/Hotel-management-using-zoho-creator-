			Send_payment_notification as "Send payment notification"
			{
				type =  form
				form = Reservation

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Payment_type == "Online payment")
										{
											// Payment Confirmation Card Container
											payment_html = "<html><body style=\"background-color:#f2f2f2; padding:50px; font-family:sans-serif;\">";
											payment_html = payment_html + "<div style='width:320px; background:white; border-radius:15px; padding:30px; margin:auto; text-align:center; box-shadow: 0 4px 15px rgba(0,0,0,0.1);'>";
											// 1. SUCCESS ICON (Green Circle with Checkmark)
											payment_html = payment_html + "<div style='margin-bottom:20px;'>";
											payment_html = payment_html + "<img src='https://cdn-icons-png.flaticon.com/512/5610/5610944.png' style='width:70px; height:70px;'>";
											payment_html = payment_html + "</div>";
											// 2. HEADER
											payment_html = payment_html + "<h2 style='font-size:24px; color:#1a1a1a; margin:0 0 25px 0;'>Payment Confirmed !</h2>";
											// 3. TRANSACTION DETAILS TABLE
											payment_html = payment_html + "<table width='100%' border='0' cellspacing='0' cellpadding='8' style='font-size:14px; color:#444;'>";
											// Amount Row
											payment_html = payment_html + "<tr>";
											payment_html = payment_html + "<td style='text-align:left; font-weight:bold;'>Amount:</td>";
											payment_html = payment_html + "<td style='text-align:right;'>₹" + ifnull(input.Total_amount,"0.00") + "</td>";
											payment_html = payment_html + "</tr>";
											// Date Row
											payment_date = zoho.currenttime.toString("MMM dd, yyyy","Asia/Kolkata");
											payment_html = payment_html + "<tr>";
											payment_html = payment_html + "<td style='text-align:left; font-weight:bold;'>Date:</td>";
											payment_html = payment_html + "<td style='text-align:right;'>" + zoho.currenttime + "</td>";
											payment_html = payment_html + "</tr>";
											//from payment 
											payment_html = payment_html + "<tr>";
											payment_html = payment_html + "<td style='text-align:left; font-weight:bold;'>Transaction from</td>";
											payment_html = payment_html + "<td style='text-align:right;'>" + input.Guest_details.Guest_name + "</td>";
											payment_html = payment_html + "</tr>";
											// Transaction ID Row
											payment_html = payment_html + "<tr>";
											payment_html = payment_html + "<td style='text-align:left; font-weight:bold;'>Transaction to</td>";
											payment_html = payment_html + "<td style='text-align:right;'>" + "Hills Grand Hotel" + "</td>";
											payment_html = payment_html + "</tr>";
											payment_html = payment_html + "</table>";
											// 4. DONE BUTTON
											// 	payment_html = payment_html + "<div style='margin-top:30px;'>";
											// 	payment_html = payment_html + "<div style='background:#444; color:white; padding:12px; border-radius:8px; font-weight:bold; cursor:pointer; text-transform:uppercase; font-size:14px; letter-spacing:1px;'>Done</div>";
											// 	payment_html = payment_html + "</div>";
											payment_html = payment_html + "</div></body></html>";
											pdfFile1 = zoho.file.convertToPDF(payment_html);
											sendmail
											[
												from :"zentegrademo31@gmail.com"
												to :input.Email
												cc:"manikandansjobzen@gmail.com"
												reply to :"manikandan@zentegra.com"
												subject :"Your Hotel Reservation Ticket - Hills Hotel"
												message :"Congratulations ! Your online payment was successfull, Please find the payment confirmation receipt below."
												Attachments :file:pdfFile1
											]
										}
										else
										{
											sendmail
											[
												from :"zentegrademo31@gmail.com"
												to :input.Email
												cc:"manikandansjobzen@gmail.com"
												reply to :"manikandan@zentegra.com"
												subject :"Your Hotel Reservation Ticket - Hills Hotel"
												message :"Congratulations ! Your cash payment of an amount " + " " + "rupees" + " " + input.Total_amount + " was successfull."
											]
										}
						)
					}
				}

			}
			Disable_fields as "Disable fields"
			{
				type =  form
				form = Service_bill

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable Date_Time;
										disable Total;
										disable Tax_Amount;
										disable Charge;
						)
					}
				}

			}
			Date_time_default_filling as "Date time default filling"
			{
				type =  form
				form = Service_bill

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											input.Date_Time = zoho.currenttime.toString("yyyy-MM-dd HH:mm:ss","Asia/Kolkata");
						)
					}
				}

			}
		}






