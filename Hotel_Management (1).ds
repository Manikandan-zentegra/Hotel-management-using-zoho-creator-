											input.Total_amount = 100;
										}
										else if(input.Mini_Bar == "Whisky")
										{
											input.Total_amount = 150;
										}
										else if(input.Mini_Bar == "Rum")
										{
											input.Total_amount = 200;
										}
										else if(input.Mini_Bar == "Odka")
										{
											input.Total_amount = 250;
										}
										else if(input.Mini_Bar == "Wine")
										{
											input.Total_amount = 300;
										}
										else if(input.Mini_Bar == "Cocktail")
										{
											input.Total_amount = 450;
										}
										else
										{
											input.Total_amount = 0;
										}
						)
					}
				}

			}
