						custom deluge script
						(
											if(input.Room_cleaning == "Cleaning floor")
										{
											input.Charge = 25;
											input.Tax_Amount = 3;
											input.Total = 28;
										}
										else if(input.Room_cleaning == "Clean the mirror / things")
										{
											input.Charge = 20;
											input.Tax_Amount = 2;
											input.Total = 22;
										}
										else if(input.Room_cleaning == "Deep cleaning")
										{
											input.Charge = 30;
											input.Tax_Amount = 5;
											input.Total = 35;
										}
										else if(input.Room_cleaning == "Public area cleaning")
										{
											input.Charge = 100;
											input.Tax_Amount = 10;
											input.Total = 110;
										}
										else if(input.Room_cleaning == "Laundry Services")
										{
											input.Charge = 25;
											input.Tax_Amount = 25;
											input.Total = 50;
										}
										else if(input.Room_cleaning == "Washroom cleaning")
										{
											input.Charge = 35;
											input.Tax_Amount = 5;
											input.Total = 40;
										}
										else
										{
											input.Charge = 0;
											input.Tax_Amount = 0;
											input.Total = 0;
										}
						)
					}
				}

			}
