			Date_time_validation as "Date time validation"
			{
				type =  form
				form = Service_bill

				record event = on add or edit

				on user input of Date_Time
				{
					actions 
					{
						custom deluge script
						(
											// Check if input date is before today
										if(input.Date_Time < zoho.currentdate)
										{
											// Alert the user and clear the field
											alert "Past dates cannot be selected.";
											input.Date_Time = null;
										}
						)
					}
				}

