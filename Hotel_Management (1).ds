			Gpay_qr_code_generator as "Gpay qr code generator"
			{
				type =  form
				form = Service_bill

				record event = on add or edit

				on user input of Total
				{
					actions 
					{
						custom deluge script
						(
											// 1. Configuration
										vpa = "manikandans250903@okaxis";
										merchantName = "Service amount";
										// Convert the number to a string to prevent errors
										amountStr = input.Total.toString();
										currency = "INR";
										// Use a fallback if the ID is not yet generated
										currentID = ifnull(input.ID,"New_Guest");
										transactionNote = "Payment for " + currentID;
										// 2. Build and Encode the UPI String
										// We encode the parts to handle spaces and special characters
										encodedName = zoho.encryption.urlEncode(merchantName);
										encodedNote = zoho.encryption.urlEncode(transactionNote);
										upiString = "upi://pay?pa=" + vpa + "&pn=" + encodedName + "&am=" + amountStr + "&cu=" + currency + "&tn=" + encodedNote;
										// 3. Generate the QR Code URL
										// We encode the entire UPI string so the API can read it
										encodedUpi = zoho.encryption.urlEncode(upiString);
										qrUrl = "https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=" + encodedUpi;
										// 4. Update the Note field
										// This sends the HTML image tag to your Note field
										Payment_QR = "<div><p style='font-weight:bold;'>Scan to pay via GPay:</p><img src='" + qrUrl + "' alt='QR Code' /></div>";
						)
					}
				}

			}
			GPay_qr_generator as "GPay qr generator"
			{
				type =  form
				form = Reservation

				record event = on add or edit

				on user input of Total_amount
				{
					actions 
					{
						custom deluge script
						(
											// 1. Show the QR field (ensures it is visible)
										show Payment_QR;
										// 2. Configuration
										vpa = "manikandans250903@okaxis";
										merchantName = "Service amount";
										currency = "INR";
										// Ensure we are using the correct field for the amount
										// If your field is 'Total', change 'Total_amount' to 'Total'
										amountStr = ifnull(input.Total_amount,0).toString();
										// Handle ID for new records
										currentID = ifnull(input.ID,"0").toString();
										transactionNote = "Payment for Guest-" + currentID;
										// 3. Advanced UPI Parameters (Fixes the 'Add Bank Account' issue)
										merchantCode = "0000";
										// Standard generic code
										transactionRef = "TXN" + zoho.currenttime.toLong();
										// Generates a unique reference
										// 4. Build and Encode
										encodedName = zoho.encryption.urlEncode(merchantName);
										encodedNote = zoho.encryption.urlEncode(transactionNote);
										// Constructing the full UPI string with mc and tr parameters
										upiString = "upi://pay?pa=" + vpa + "&pn=" + encodedName + "&am=" + amountStr + "&cu=" + currency + "&tn=" + encodedNote + "&mc=" + merchantCode + "&tr=" + transactionRef;
										// 5. Generate QR URL
										encodedUpi = zoho.encryption.urlEncode(upiString);
										qrUrl = "https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=" + encodedUpi;
										// 6. Update the Note field with the QR Image
										// Added a safety check: Only show QR if amount > 0
										if(input.Total_amount > 0)
										{
											input.Payment_QR = "<div><br><img src='" + qrUrl + "' style='border:2px solid #ccc; border-radius:10px;' /><br><p style='font-family:sans-serif;'><b>Amount to Pay: ₹" + amountStr + "</b></p></div>";
										}
										else
										{
											input.Payment_QR = "Please enter an amount to generate QR code.";
										}
						)
					}
				}

			}
