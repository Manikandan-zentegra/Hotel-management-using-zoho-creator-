			Send_amenities_bill_in_ma as "Send amenities bill in mail"
			{
				type =  form
				form = Amenities_bill

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											ticket_html = "";
										ticket_html = ticket_html + "<html>";
										ticket_html = ticket_html + "<head><meta charset='UTF-8'><title>Amenities invoice</title></head>";
										ticket_html = ticket_html + "<body style='margin:0;padding:20px;background:#f4f6f8;font-family:Segoe UI,Arial;'>";
										ticket_html = ticket_html + "<table width='100%' cellspacing='0' cellpadding='0'><tr><td align='center'>";
										ticket_html = ticket_html + "<table width='600' style='background:#ffffff;border-radius:10px;padding:25px;'>";
										ticket_html = ticket_html + "<tr><td style='text-align:center;border-bottom:2px dashed #ddd;padding-bottom:15px;'>";
										ticket_html = ticket_html + "<h1 style='margin:0;color:#2c3e50;'>Welcome to Hill grand hotel</h1>";
										ticket_html = ticket_html + "<p style='color:#777;font-size:14px;'>Thank you for choosing our service !</p>";
										// ticket_html = ticket_html + "<span style='background:#27ae60;color:#fff;padding:6px 14px;border-radius:20px;font-size:12px;'>PAID ✅</span>";
										ticket_html = ticket_html + "<span style='padding:6px 14px;border-radius:20px;font-size:12px;'>" + input.Date_Time + "</span>";
										ticket_html = ticket_html + "</td></tr>";
										ticket_html = ticket_html + "<tr><td>";
										ticket_html = ticket_html + "<table width='100%' style='font-size:14px;margin-top:20px;'>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Customer name</td><td style='padding:10px;'>" + input.Customer_Name + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Room number</td><td style='padding:10px;'>" + input.Room_number + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Room type</td><td style='padding:10px;'>" + input.Room + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Selected amenities</td><td style='padding:10px;'>" + input.Select_Amenities + "</td></tr>";
										if(input.Select_Amenities == "Food and reverage")
										{
											if(input.Food_and_reverage == "Mini - Bar")
											{
												ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Mini bar</td><td style='padding:10px;'>" + input.Mini_Bar + "</td></tr>";
											}
											else
											{
												ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Restaurant meals</td><td style='padding:10px;'>" + input.Restaurant_meals + "</td></tr>";
											}
										}
										else if(input.Select_Amenities == "Facilities")
										{
											if(input.Facilities == "Gym access")
											{
												ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Gym access</td><td style='padding:10px;'>" + input.Gym_access + "</td></tr>";
											}
											else
											{
												ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Swimming pool</td><td style='padding:10px;'>" + input.Swimming_pool + "</td></tr>";
											}
										}
										else if(input.Select_Amenities == "Services")
										{
											if(input.Services == "Laundry / dry cleaning")
											{
												ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Laundry / dry cleaning</td><td style='padding:10px;'>" + input.Laundry + "</td></tr>";
											}
											else
											{
												ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Physio treatment</td><td style='padding:10px;'>" + input.Physio_treatment + "</td></tr>";
											}
										}
										// ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>phone</td><td style='padding:10px;'>" + input.Enter_your_phone_number + "</td></tr>";
										// ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Snacks type</td><td style='padding:10px;'>" + input.Select_the_snacks_type + "</td></tr>";
										ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Total amount</td><td style='padding:10px;'>" + input.Total_amount + "</td></tr>";
										ticket_html = ticket_html + "<tr>" + "<td style='padding:10px;color:#555;'>QR code</td>" + "<td style='padding:10px;color:#27ae60;font-weight:bold;'>" + "<img src='https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=" + input.Total_amount + "'style='width:120px;height:120px;'>" + "</td>" + "</tr>";
										ticket_html = ticket_html + "</table>";
										ticket_html = ticket_html + "</td></tr>";
										ticket_html = ticket_html + "</table>";
										ticket_html = ticket_html + "</td></tr></table>";
										ticket_html = ticket_html + "</body></html>";
										sendmail
										[
											from :"zentegrademo31@gmail.com"
											to :input.Customer_email
											cc:"manikandansjobzen@gmail.com"
											reply to :"manikandan@zentegra.com"
											subject :"Welcome to hills grand hotel amenities services"
											message :ticket_html
										]
						)
					}
				}

			}
