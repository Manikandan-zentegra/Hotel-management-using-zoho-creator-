			enable_snacks as "enable snacks"
			{
				type =  form
				form = Service_bill

				record event = on add or edit

				on user input of Choose_service
				{
					actions 
					{
						custom deluge script
						(
											if(input.Choose_service == "Food service")
										{
											show Snacks;
										}
										else if(input.Choose_service != "Food service")
										{
											hide Snacks;
										}
										else if(input.Choose_service == null)
										{
											input.Charge = 0;
											input.Tax_Amount = 0;
											input.Total = 0;
										}
						)
					}
				}

			}
			hide_fields as "hide fields"
