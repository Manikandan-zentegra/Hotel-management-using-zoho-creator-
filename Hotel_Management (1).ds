					form  Reservation
					{
						icon = "travel-fire"
					}
					report All_Reservations
					{
						icon = "tech-desktop"
					}
				}
				section App_Preferences
				{
					displayname = "App Preferences"
					icon = "design-app"
					systemcomponent
					{
						type = localization
