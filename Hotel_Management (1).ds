		workflow
		{
		form
		{
			Hide_show_fields as "Hide/show fields"
			{
				type =  form
				form = Reservation

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											//reservation form
										hide Company_name;
										// hide Guest;
										hide Room_type;
										hide Room_tariff;
										hide Tax_amount;
										hide Advance_amount;
										hide Total_amount;
										hide Payment_status;
										hide ID1;
										hide Employee_ID;
										// hide Name_of_the_employee;
										hide ID1;
										hide Number_of_days_stayed;
										hide Payment_QR;
										hide AC_room_number;
										hide Normal_room_number;
										hide Payment_type;
						)
					}
				}

			}
			Show_comapny_and_guest as "Show comapny and guest"
			{
				type =  form
				form = Reservation

				record event = on add or edit

				on user input of Guest_type
				{
					actions 
					{
						custom deluge script
						(
											if(input.Guest_type == "Corporate")
										{
											show Company_name;
											show Employee_ID;
											// 	show Name_of_the_employee;
										}
										// else if(input.Guest_type == "Individual")
										// {
										// 	show Guest;
										// }
										else
										{
											hide Company_name;
											// 	hide Guest;
											hide Employee_ID;
											// 	hide Name_of_the_employee;
										}
						)
					}
				}

			}
			Show_payment_details_sect as "Show payment details section"
			{
				type =  form
				form = Reservation

				record event = on add or edit

				on user input of Confirm_reservation
				{
					actions 
					{
						custom deluge script
						(
											if(input.Confirm_reservation == true)
										{
											show Room_type;
											show Room_tariff;
											show Tax_amount;
											show Advance_amount;
											show Total_amount;
											show Payment_status;
											show ID1;
											show Number_of_days_stayed;
											show Payment_type;
										}
										else
										{
											hide Room_type;
											hide Room_tariff;
											hide Tax_amount;
											hide Advance_amount;
											hide Total_amount;
											hide Payment_status;
											hide ID1;
											hide Number_of_days_stayed;
											hide Payment_type;
										}
						)
					}
				}

			}
			Workflow_in_check_in_date as "Workflow in check in date"
			{
				type =  form
				form = Reservation

				record event = on add or edit

				on user input of Check_in_date
				{
					actions 
					{
						custom deluge script
						(
											// Check if input date is before today
										if(input.Check_in_date < zoho.currentdate)
										{
											// Alert the user and clear the field
											alert "Past dates cannot be selected.";
											input.Check_in_date = null;
										}
						)
					}
				}

			}
			Workflow_in_check_out_dat as "Workflow in check out date"
			{
				type =  form
				form = Reservation

				record event = on add or edit

				on user input of Check_out_date
				{
					actions 
					{
						custom deluge script
						(
											// Check if input date is before today
										if(input.Check_out_date < input.Check_in_date)
										{
											// Alert the user and clear the field
											alert "Checkout date not previous then Checkin date";
											input.Check_out_date = null;
										}
						)
					}
				}

			}
			Generate_ID as "Generate ID"
			{
				type =  form
				form = Reservation

				record event = on add or edit

				on user input of Payment_status
				{
					actions 
					{
						custom deluge script
						(
											// 1. Fetch the latest record
										lastRecord = Reservation[ID != 0] sort by Added_Time desc;
										// 2. Get the string and extract ONLY the numbers
										lastIDString = ifnull(lastRecord.ID1,"0");
										// This regex removes everything that is NOT a digit (0-9)
										lastNumString = lastIDString.replaceAll("[^0-9]","");
										// 3. Convert to number (default to 0 if the string is empty)
										lastNum = if(lastNumString == "",0,lastNumString.toLong());
										// 4. Increment and set the field
										newNum = lastNum + 1;
										input.ID1 = "Guest-" + newNum;
						)
					}
				}

			}
			Disable_ID1 as "Disable ID"
			{
				type =  form
				form = Reservation

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable ID1;
										disable Guest_details.Age;
										disable Number_of_days_stayed;
						)
					}
				}

			}
			Hide_show_guest_ID as "Hide & show guest ID"
			{
				type =  form
				form = Reservation

				record event = on add or edit

				on user input of Payment_status
				{
					actions 
					{
						custom deluge script
						(
											if(input.Payment_status == "Completed" || input.Payment_status == "Awaiting")
										{
											show ID1;
										}
										else
										{
											hide ID1;
										}
						)
					}
				}

			}
			test as "test"
			{
				type =  form
				form = Reservation

				record event = on add or edit

				on user input of Advance_amount
				{
					actions 
					{
						custom deluge script
						(
											cost_for_acroom = 800;
										cost_for_normalroom = 600;
										calculate_amount_acroom = cost_for_acroom * input.Number_of_days_stayed;
										calculate_amount_normalroom = cost_for_normalroom * input.Number_of_days_stayed;
										tax_acroom = 200;
										tax_normalroom = 100;
										calculate_totaltax_for_acroom = tax_acroom * input.Number_of_days_stayed;
										calculate_totaltax_for_normalroom = tax_acroom * input.Number_of_days_stayed;
										new_var = input.Total_amount;
										no_of_rooms = input.Number_of_rooms;
										if(input.Room_type == "AC room")
										{
											if(input.Advance_amount != null)
											{
												amount = calculate_amount_acroom + calculate_totaltax_for_acroom + input.Room_tariff;
												room = amount * no_of_rooms;
												input.Total_amount = room - input.Advance_amount;
												input.Tax_amount = calculate_totaltax_for_acroom;
											}
											else
											{
												amount = calculate_amount_acroom + calculate_totaltax_for_acroom + input.Room_tariff + input.Advance_amount;
												// 		info input.Advance_amount ;
												room = amount * new_var;
												input.Total_amount = room;
												input.Tax_amount = calculate_totaltax_for_acroom;
											}
										}
										else if(input.Room_type == "Normal room")
										{
											if(input.Advance_amount != null)
											{
												amount = calculate_amount_normalroom + calculate_totaltax_for_normalroom + input.Room_tariff;
												input.Total_amount = amount - input.Advance_amount;
												input.Tax_amount = calculate_totaltax_for_normalroom;
											}
											else
											{
												amount = calculate_amount_normalroom + calculate_totaltax_for_normalroom + input.Room_tariff;
												input.Total_amount = amount;
												input.Tax_amount = calculate_totaltax_for_normalroom;
											}
										}
						)
					}
				}

			}
			Disable_in_shift_a_room as "Disable in shift a room"
			{
				type =  form
				form = Shift_a_room

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											disable Apply_rate;
						)
					}
				}

			}
			Block_from_date_field as "Block from date field"
			{
				type =  form
				form = Maintenance_Block

				record event = on add or edit

				on user input of Block_from
				{
					actions 
					{
						custom deluge script
						(
											// Check if input date is before today
										if(input.Block_from < zoho.currentdate)
										{
											// Alert the user and clear the field
											alert "Past dates cannot be selected.";
											input.Block_from = null;
										}
						)
					}
				}

			}
			Block_to_field as "Block to  field"
			{
				type =  form
				form = Maintenance_Block

				record event = on add or edit

				on user input of Block_to
				{
					actions 
					{
						custom deluge script
						(
											// Check if input date is before today
										if(input.Block_to < input.Block_from)
										{
											// Alert the user and clear the field
											alert "Checkout date not previous then Checkin date";
											input.Block_to = null;
										}
						)
					}
				}

			}
			amount_showing as "amount showing"
			{
				type =  form
				form = Service_bill

				record event = on add or edit

				on user input of Snacks
				{
					actions 
					{
						custom deluge script
						(
											if(input.Snacks == "Veg puffs")
										{
											input.Charge = 30;
											input.Tax_Amount = 3;
											input.Total = 33;
										}
										else if(input.Snacks == "Egg puffs")
										{
											input.Charge = 45;
											input.Tax_Amount = 4;
											input.Total = 49;
										}
										else if(input.Snacks == "Cookies")
										{
											input.Charge = 25;
											input.Tax_Amount = 2;
											input.Total = 27;
										}
										else if(input.Snacks == "Pizza")
										{
											input.Charge = 99;
											input.Tax_Amount = 8;
											input.Total = 107;
										}
										else if(input.Snacks == "Burger")
										{
											input.Charge = 85;
											input.Tax_Amount = 7;
											input.Total = 92;
										}
										else
										{
											input.Charge = 0;
											input.Tax_Amount = 0;
											input.Total = 0;
										}
						)
					}
				}

			}
			Bill_to_customer as "Bill to customer"
			{
				type =  form
				form = Service_bill

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											if(input.Choose_service == "Food service")
										{
											ticket_html = "";
											ticket_html = ticket_html + "<html>";
											ticket_html = ticket_html + "<head><meta charset='UTF-8'><title>Hotel Management Snacks Bill</title></head>";
											ticket_html = ticket_html + "<body style='margin:0;padding:20px;background:#f4f6f8;font-family:Segoe UI,Arial;'>";
											ticket_html = ticket_html + "<table width='100%' cellspacing='0' cellpadding='0'><tr><td align='center'>";
											ticket_html = ticket_html + "<table width='600' style='background:#ffffff;border-radius:10px;padding:25px;'>";
											ticket_html = ticket_html + "<tr><td style='text-align:center;border-bottom:2px dashed #ddd;padding-bottom:15px;'>";
											ticket_html = ticket_html + "<h1 style='margin:0;color:#2c3e50;'>Welcome to Hills Grand Hotel snacks</h1>";
											ticket_html = ticket_html + "<p style='color:#777;font-size:12px;'>Thank you for choosing our service, Enjoy your snacks !</p>";
											ticket_html = ticket_html + "<span style='padding:6px 14px;border-radius:20px;font-size:12px;'>" + input.Date_Time + "</span>";
											ticket_html = ticket_html + "</td></tr>";
											ticket_html = ticket_html + "<tr><td>";
											ticket_html = ticket_html + "<table width='100%' style='font-size:14px;margin-top:20px;'>";
											ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Customer name</td><td style='padding:10px;'>" + input.Customer_name + "</td></tr>";
											ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Room number</td><td style='padding:10px;'>" + input.Room_number + "</td></tr>";
											ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Date time</td><td style='padding:10px;'>" + input.Date_Time + "</td></tr>";
											ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Mail</td><td style='padding:10px;'>" + input.Email + "</td></tr>";
											ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>phone</td><td style='padding:10px;'>" + input.Phone_number + "</td></tr>";
											ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Snacks type</td><td style='padding:10px;'>" + input.Snacks + "</td></tr>";
											ticket_html = ticket_html + "<tr><td style='padding:10px;color:#555;'>Price</td><td style='padding:10px;'>" + input.Total + "</td></tr>";
