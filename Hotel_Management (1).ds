			Calculate_guest_age as "Calculate guest age"
			{
				type =  form
				form = Reservation

				record event = on add or edit

				on user input of Guest_details.Date_of_birth
				{
					actions 
					{
						custom deluge script
						(
											if(row.Date_of_birth != null)
										{
											dateOfBirth = row.Date_of_birth;
											currentDate = zoho.currentdate;
											// Calculate age using the yearsBetween function
											input.Guest_details.Age = yearsBetween(dateOfBirth,currentDate);
											//     row.age = age;
										}
										else
										{
											input.Guest_details.Age = null;
										}
						)
					}
				}

			}
			Send_reservation_ticket as "Send reservation ticket"
			{
				type =  form
				form = Reservation

				record event = on add or edit

				on success
				{
					actions 
					{
						custom deluge script
						(
											// Main Container - Width set to 1200px (1700px is too wide for most email screens)
										ticket_html = "<html><body style=\"font-family: 'Georgia', serif; background:#f2f2f2; padding:20px;\">";
										ticket_html = ticket_html + "<table width='900' height='330' align='center' cellpadding='0' cellspacing='0' style='background:white; border-radius:12px; overflow:hidden; box-shadow:0 4px 10px rgba(0,0,0,0.2); border-collapse:collapse;'>";
										ticket_html = ticket_html + "<tr>";
										// 1. LEFT RED STRIP
										ticket_html = ticket_html + "<td width='80' bgcolor='#d06666' style='text-align:center; vertical-align:middle;'>";
										ticket_html = ticket_html + "<div style='writing-mode:vertical-rl; transform:rotate(180deg); color:#ffffff; font-weight:bold; letter-spacing:2px; font-size:16px;'>Confirmed Reservation</div>";
										ticket_html = ticket_html + "</td>";
										// 2. MIDDLE SECTION (Guest Details)
										ticket_html = ticket_html + "<td style='padding:20px; vertical-align:top;'>";
										// ticket_html = ticket_html + "<h3 style='text-align:center; font-size:20px; letter-spacing:3px; font-weight:normal; margin:0;'>You have</h3>";
										ticket_html = ticket_html + "<h1 style='text-align:center; font-size:22px; margin:5px 0;'>Hotel Reservation</h1>";
										ticket_html = ticket_html + "<div style='text-align:center; border-top:1px solid #ccc; border-bottom:1px solid #ccc; padding:8px; margin-bottom:20px;'>At Hills Grand Hotel</div>";
										// Details Row
										ticket_html = ticket_html + "<table width='100%'><tr>";
										// Date Box
										ticket_html = ticket_html + "<td width='100' style='border:1px solid #ccc; padding:15px; text-align:center; vertical-align:middle; background:#f9f9f9;'>";
										ticket_html = ticket_html + input.Check_in_date.toString("MMM") + "<br>";
										ticket_html = ticket_html + "<h2 style='margin:5px 0;'>" + input.Check_in_date.toString("dd") + "</h2>";
										ticket_html = ticket_html + input.Check_in_date.toString("yyyy");
										ticket_html = ticket_html + "</td>";
										// Text Info
										ticket_html = ticket_html + "<td style='padding-left:15px; font-size:10px; line-height:1.6;'>";
										ticket_html = ticket_html + "<b>Guest : </b> " + ifnull(input.Guest_details.Guest_name,"-") + "<br>";
										ticket_html = ticket_html + "<b>Gender : </b> " + ifnull(input.Guest_details.Gender,"-") + "<br>";
										ticket_html = ticket_html + "<b>Guest Type : </b> " + ifnull(input.Guest_type,"-") + "<br>";
										ticket_html = ticket_html + "<b>Guest mobile number : </b> " + ifnull(input.Mobile_number,"-") + "<br>";
										ticket_html = ticket_html + "<b>Guest ID : </b> " + ifnull(input.ID1,"-") + "<br>";
										ticket_html = ticket_html + "<b>Guest Aadhar no. : </b> " + ifnull(input.Guest_details.Aadhar_number,"-") + "<br>";
										ticket_html = ticket_html + "<b>Room type : </b> " + ifnull(input.Room_type,"-") + "<br>";
										ticket_html = ticket_html + "<b>Check-out date : </b> " + ifnull(input.Check_out_date.toString()," - ") + "<br>";
										if(input.Employee_ID != null)
										{
											ticket_html = ticket_html + "<b>Employee ID : </b> " + input.Employee_ID + "<br>";
										}
										ticket_html = ticket_html + "<p style='margin:15px 0 0 0; color:#2e8b57; font-weight:bold; font-size:10px;'>Balance amount to pay: ₹" + ifnull(input.Total_amount,0) + "</p>";
										calculate_total = input.Total_amount + input.Advance_amount;
										ticket_html = ticket_html + "<p style='margin:15px 0 0 0; color:#2e8b57; font-weight:bold; font-size:10px;'>Total amount : ₹" + calculate_total + "</p>";
										ticket_html = ticket_html + "</td></tr></table>";
										// T&C
										ticket_html = ticket_html + "<p style='font-size:10px; margin-top:30px; color:#666;'>Terms & conditions : Valid for " + ifnull(input.Guest_details.Guest_name,"Guest") + " only. ID proof required at check-in.</p>";
										ticket_html = ticket_html + "<p style='font-size:10px; margin-top:30px; color:#666;'>This is system generated reservation ticket.</p>";
										ticket_html = ticket_html + "</td>";
										// 3. RIGHT SECTION - Reduced width to 220px to make it tighter
										ticket_html = ticket_html + "<td width='220' style='border-left:2px dashed #ccc; padding:15px; vertical-align:middle; text-align:center;'>";
										// Luggage Image (Centered)
										ticket_html = ticket_html + "<img src='https://img.freepik.com/premium-vector/vector-travel-suitcase-travel-bag-icon-illustration-trolley-bag-logo-icon_602177-99.jpg' style='width:90px; height:auto; margin-bottom:15px;'>";
										// Address Table - Using a more reliable Location Icon link
										ticket_html = ticket_html + "<table align='center' border='0' cellpadding='0' cellspacing='0' style='width:100%;'>";
										ticket_html = ticket_html + "<tr>";
										// Location Icon Cell (Left side of the address text)
										ticket_html = ticket_html + "<td style='vertical-align:top; width:25px; padding-top:2px;'>";
										ticket_html = ticket_html + "<img src='https://cdn-icons-png.flaticon.com/512/684/684908.png' style='width:18px; height:18px;'>";
										ticket_html = ticket_html + "</td>";
										// Address Text Cell
										ticket_html = ticket_html + "<td style='text-align:left; font-family:sans-serif;'>";
										ticket_html = ticket_html + "<strong style='font-size:12px; color:#000;'>Hills Grand Hotel</strong><br>";
										ticket_html = ticket_html + "<span style='font-size:10px; color:#444; line-height:1.4;'>245 Mountain View Ave,<br>Riverdale, Karnataka<br>560102, India</span>";
										ticket_html = ticket_html + "</td>";
										ticket_html = ticket_html + "</tr>";
										ticket_html = ticket_html + "</table>";
										ticket_html = ticket_html + "</td>";
										ticket_html = ticket_html + "</tr>";
										ticket_html = ticket_html + "</table>";
										ticket_html = ticket_html + "</body></html>";
										pdfFile1 = zoho.file.convertToPDF(ticket_html);
										//combining two messages to send in one message
										intro_text = "Dear Guest," + " " + input.Guest_details.Guest_name + " " + " <br><br> Your reservation is confirmed. Please find your ticket below:<br><br>";
										final_message = intro_text + ticket_html;
										// Send Mail Task
										sendmail
										[
											from :"zentegrademo31@gmail.com"
											to :input.Email
											cc:"manikandansjobzen@gmail.com"
											reply to :"manikandan@zentegra.com"
											subject :"Your Hotel Reservation Ticket - Hills Hotel"
											message :final_message
											Attachments :file:pdfFile1
										]
						)
					}
				}

			}
			Calculate_number_of_days as "Calculate number of days"
			{
				type =  form
				form = Reservation

				record event = on add or edit

				on user input of Check_out_date
				{
					actions 
					{
						custom deluge script
						(
											if(Check_out_date != null)
										{
											startDate = input.Check_in_date;
											endDate = input.Check_out_date;
											numberOfDays = daysBetween(startDate,endDate);
											input.Number_of_days_stayed = numberOfDays;
										}
										else
										{
											input.Number_of_days_stayed = null;
										}
						)
					}
				}

			}
